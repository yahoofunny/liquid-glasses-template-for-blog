    <h1 class="text-3xl font-bold mb-6">About</h1>
    <div class="prose max-w-none text-white/70">
      <p class="text-lg">A blog built with Astro.</p>
      <p>Powered by glassmorphism design.</p>
    </div>
  </div>
</PageLayout>
